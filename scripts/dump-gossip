#!/usr/bin/env bash
set -euo pipefail

NODES=(a b c d e f)
DEBUG_DIR="$(cd "$(dirname "$0")/.." && pwd)/debug"

mkdir -p "$DEBUG_DIR"

for node in "${NODES[@]}"; do
  echo "Dumping gossip logs for node-$node..."
  kubectl logs -l app=kels-gossip --tail 10000 -n "kels-node-$node" > "$DEBUG_DIR/gossip-$node.log" 2>&1 &
done

wait
echo "Done. Files in $DEBUG_DIR/"
