#!/usr/bin/env bash
set -euo pipefail

if [ $# -ne 1 ]; then
  echo "Usage: $0 <PREFIX>"
  exit 1
fi

PREFIX="$1"
NODES=(a b c d e f)
DEBUG_DIR="$(cd "$(dirname "$0")/.." && pwd)/debug"

mkdir -p "$DEBUG_DIR"

for node in "${NODES[@]}"; do
  echo "Fetching node-$node..."
  curl -s "http://kels.kels-node-$node.kels/api/v1/kels/kel/$PREFIX" | jq . > "$DEBUG_DIR/node-$node.kel" &
  kubectl logs -l app=kels-gossip --tail 10000 -n "kels-node-$node" | grep -A2 -B2 "$PREFIX" > "$DEBUG_DIR/node-$node.gossip" 2>&1 &
done

wait
echo "Done. Files in $DEBUG_DIR/"
